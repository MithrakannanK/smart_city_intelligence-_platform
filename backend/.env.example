PORT=4000
NODE_ENV=development

# MongoDB (optional for guest mode, but used for personalization + alert logs)
MONGODB_URI=mongodb://localhost:27017/urbanmindai

# Frontend origin for CORS (adjust to your dev URL)
CORS_ORIGIN=http://localhost:5173

# Google APIs (enable these in Google Cloud Console)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
GOOGLE_GEOCODING_API_KEY=YOUR_GOOGLE_GEOCODING_API_KEY

# Places/Directions are part of Maps Platform; use same key if desired

# Weather + Air quality provider (using OpenWeather Air Pollution)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# LLM provider (choose one)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
LLM_MODEL_OPENAI=gpt-4o-mini
LLM_MODEL_GEMINI=gemini-1.5-flash

# If set, the backend will never call external LLMs and will use rule-based scoring.
LLM_DISABLED=false

